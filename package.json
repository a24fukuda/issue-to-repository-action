{
  "name": "issue-to-repository-action",
  "version": "1.0.0",
  "private": true,
  "description": "Sync GitHub Issues into repository files as portable, version-controlled records.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && bun build ./src/main.ts --outfile=dist/index.js --target=node --format=cjs --minify",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^9.1.1",
    "@octokit/plugin-throttling": "^11.0.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "undici": "^6.27.0"
  }
}
