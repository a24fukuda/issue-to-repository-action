{
  "name": "issue-to-repository-action",
  "version": "1.0.0",
  "private": true,
  "description": "Sync GitHub Issues into repository files as portable, version-controlled records.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/main.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --minify",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^9.1.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "overrides": {
    "undici": "^6.27.0"
  }
}
